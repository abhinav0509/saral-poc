{
  "expo": {
    "name": "Saral Staff",
    "slug": "saral-staff",
    "scheme": "saralstaff",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E5E5A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.saral.staff"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.saral.staff",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/monochrome-icon.png",
        "backgroundColor": "#0E5E5A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/monochrome-icon.png",
          "color": "#0E5E5A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "db31682f-8bb8-4701-bc86-e402f3f5a37b"
      }
    },
    "owner": "abhinav-davinci",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/db31682f-8bb8-4701-bc86-e402f3f5a37b"
    }
  }
}
